  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-titles-from-headings"
  gem "jekyll-paginate-v2"
  gem "jekyll-default-layout"
  gem "jekyll-gist"
  gem "jekyll-twitter-plugin"
  gem "jemoji"
  gem "jekyll-link-attributes"
end

gem "webrick", "~> 1.8"
